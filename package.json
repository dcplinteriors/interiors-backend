{
  "name": "dcpl-backend",
  "version": "0.1.0",
  "private": true,
  "description": "DCPL Interior — backend REST API (Node + TypeScript)",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "seed:admin": "tsx scripts/seedAdmin.ts",
    "seed:supervisor": "tsx scripts/seedSupervisor.ts",
    "seed:request": "tsx scripts/seedRequest.ts",
    "reset-link": "tsx scripts/resetLink.ts",
    "get-token": "tsx scripts/getToken.ts",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:emulator": "firebase emulators:exec --only firestore --project demo-dcpl \"jest --config jest.emulator.config.js\"",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "firebase-admin": "^12.6.0",
    "helmet": "^8.0.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.9.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "firebase-tools": "^13.29.1",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0"
  }
}
