# Copy to .env and fill in. .env is gitignored.
NODE_ENV=development
PORT=8080

# Firebase
FIREBASE_PROJECT_ID=
# Option 1: path to a service-account JSON file
GOOGLE_APPLICATION_CREDENTIALS=
# Option 2 (alternative): the service-account JSON inline (single line)
FIREBASE_SERVICE_ACCOUNT=

# Web API key — triggers Firebase's built-in set-password email (supervisor invite).
# Without it, account creation still works but the invite email is skipped (logged).
FIREBASE_WEB_API_KEY=

# Optional
# Comma-separated allowed CORS origins. Unset = reflect any origin (fine for dev).
CORS_ORIGINS=
# Log level: fatal|error|warn|info|debug|trace|silent (default: info).
LOG_LEVEL=
